<?xml version="1.0"?>
<odoo>
    <record model="ir.ui.view" id="estate_property_offer_view_list">
        <field name="name">Property offer</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <list string="Offers">
                <field name="price"/>
                <field name="partner_id"/>
                <field name="validity"/>
                <field name="date_deadline"/>
                <field name="status"/>
                <button name="accept_offer" string="Confirm" type="object" icon="fa-check"/>
                <button name="refuse_offer" string="Refuse" type="object" icon="fa-times"/>
            </list>
        </field>
    </record>

    <record model="ir.ui.view" id="estate_property_offer_view_form">
        <field name="name">Property offer</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <form string="Property_form">
                <sheet>
                    <group>
                        <field name="price"/>
                        <field name="partner_id"/>
                        <field name="validity"/>
                        <field name="date_deadline"/>        
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
